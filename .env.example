# OpenHiNotes Environment Configuration
# Copy this file to .env and adjust values

# Security
SECRET_KEY=change-me-to-a-long-random-string
POSTGRES_PASSWORD=postgres

# Admin account (created on first startup)
ADMIN_EMAIL=admin@openhinotes.local
ADMIN_PASSWORD=admin

# VoxHub API Server (OpenAI-compatible transcription)
# See: https://github.com/ghecko/VoxHub
VOXHUB_API_URL=http://voxhub:8000
VOXHUB_MODEL=large-v3
# SSL verification: "true" (default), "false" (disable), or path to CA bundle
VOXHUB_VERIFY_SSL=true

# LLM API (OpenAI-compatible, for summaries and chat)
# Examples: OpenAI, Ollama (http://host.docker.internal:11434/v1), LM Studio, etc.
LLM_API_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=
LLM_MODEL=llama3
# SSL verification: "true" (default), "false" (disable), or path to CA bundle
LLM_VERIFY_SSL=true

# Speaker Voice Fingerprinting
# Encryption key for voice embeddings at rest (AES-256-GCM).
# Generate with: python -c "import os; print(os.urandom(32).hex())"
# If empty, a key is derived from SECRET_KEY (fine for dev, set explicitly in prod).
VOICE_EMBEDDING_KEY=
# Previous encryption key, used during key rotation only.
# Set this to the OLD key when rotating to a new VOICE_EMBEDDING_KEY,
# then call POST /api/voice-profiles/admin/rotate-key.
# Remove after rotation is complete.
VOICE_EMBEDDING_KEY_OLD=
# Cosine distance threshold for speaker matching (0.0=identical, 1.0=unrelated)
SPEAKER_MATCH_THRESHOLD=0.5

# OIDC / SSO
# Encryption key for OIDC client secrets at rest (AES-256-GCM).
# Generate with: python -c "import os; print(os.urandom(32).hex())"
# If empty, a key is derived from SECRET_KEY (fine for dev, set explicitly in prod).
OIDC_ENCRYPTION_KEY=

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*
