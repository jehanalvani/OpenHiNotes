# OpenHiNotes Environment Configuration
# Copy this file to .env and adjust values

# Security
SECRET_KEY=change-me-to-a-long-random-string
POSTGRES_PASSWORD=postgres

# Admin account (created on first startup)
ADMIN_EMAIL=admin@openhinotes.local
ADMIN_PASSWORD=admin

# VoxBench API Server (OpenAI-compatible transcription)
# See: https://github.com/ghecko/VoxBench
VOXBENCH_API_URL=http://voxbench:8000
VOXBENCH_MODEL=large-v3
# SSL verification: "true" (default), "false" (disable), or path to CA bundle
VOXBENCH_VERIFY_SSL=true

# LLM API (OpenAI-compatible, for summaries and chat)
# Examples: OpenAI, Ollama (http://host.docker.internal:11434/v1), LM Studio, etc.
LLM_API_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=
LLM_MODEL=llama3
# SSL verification: "true" (default), "false" (disable), or path to CA bundle
LLM_VERIFY_SSL=true

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*
