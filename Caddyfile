# Development Caddyfile (OpenHiNotes)
# Handles access via hostname

{$SITE_HOST}:443, localhost:443 {
	tls internal

	# API routes -> backend
	handle /api/* {
		reverse_proxy backend:8000
	}

	# Everything else -> frontend dev server (including Vite HMR WebSocket)
	handle {
		reverse_proxy frontend:5173 {
			flush_interval -1
		}
	}
}

# Redirect HTTP to HTTPS on the external port 8443
:80 {
	redir https://{host_only}:8443{uri} permanent
}
